{
  "name": "indra-cyber",
  "private": true,
  "version": "1.0.0",
  "description": "Indra Cyber Institute Full-Stack Project",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "cd prisma-ecommerce && npm run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "backend:install": "cd prisma-ecommerce && npm install",
    "backend:db:push": "cd prisma-ecommerce && npm run db:push",
    "backend:db:seed": "cd prisma-ecommerce && npm run seed",
    "backend:db:generate": "cd prisma-ecommerce && npm run db:generate"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^10.0.3",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
